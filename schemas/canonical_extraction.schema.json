{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/dissertation-recursive/canonical_extraction.schema.json",
  "title": "Canonical Epilepsy Clinic Letter Extraction",
  "type": "object",
  "required": ["document_id", "pipeline_id", "fields", "events", "metadata"],
  "additionalProperties": false,
  "properties": {
    "document_id": {
      "type": "string"
    },
    "pipeline_id": {
      "type": "string"
    },
    "fields": {
      "type": "object",
      "required": [
        "current_anti_seizure_medications",
        "previous_anti_seizure_medications",
        "current_seizure_frequency",
        "seizure_types",
        "eeg",
        "mri",
        "epilepsy_diagnosis"
      ],
      "additionalProperties": false,
      "properties": {
        "current_anti_seizure_medications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/medication_field"
          }
        },
        "previous_anti_seizure_medications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/medication_field"
          }
        },
        "current_seizure_frequency": {
          "$ref": "#/$defs/seizure_frequency_field"
        },
        "seizure_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar_field"
          }
        },
        "eeg": {
          "$ref": "#/$defs/investigation_field"
        },
        "mri": {
          "$ref": "#/$defs/investigation_field"
        },
        "epilepsy_diagnosis": {
          "$ref": "#/$defs/scalar_field"
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model": {
          "type": "string"
        },
        "format": {
          "enum": ["json", "yaml_to_json", "constrained_json", "unknown"]
        },
        "latency_ms": {
          "type": "number",
          "minimum": 0
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "repair_attempted": {
          "type": "boolean"
        },
        "repair_succeeded": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "missingness": {
      "enum": ["present", "not_stated", "uncertain", "conflicting", "not_applicable"]
    },
    "temporality": {
      "enum": [
        "current",
        "historical",
        "planned",
        "requested",
        "completed",
        "family_history",
        "hypothetical",
        "uncertain"
      ]
    },
    "medication_status": {
      "enum": [
        "current",
        "previous",
        "stopped",
        "declined",
        "planned",
        "increased",
        "reduced",
        "uncertain",
        "not_stated"
      ]
    },
    "investigation_status": {
      "enum": [
        "requested",
        "pending",
        "completed",
        "unavailable",
        "not_stated",
        "uncertain"
      ]
    },
    "investigation_result": {
      "enum": ["normal", "abnormal", "not_stated", "uncertain", null]
    },
    "evidence": {
      "type": "object",
      "required": ["quote"],
      "additionalProperties": false,
      "properties": {
        "quote": {
          "type": "string"
        },
        "sentence_id": {
          "type": ["string", "null"]
        },
        "char_start": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "char_end": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "scalar_field": {
      "type": "object",
      "required": ["value", "missingness", "temporality", "evidence", "evidence_event_ids"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": ["string", "null"]
        },
        "missingness": {
          "$ref": "#/$defs/missingness"
        },
        "temporality": {
          "$ref": "#/$defs/temporality"
        },
        "evidence": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "evidence_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "medication_field": {
      "type": "object",
      "required": ["name", "dose", "status", "missingness", "temporality", "evidence", "evidence_event_ids"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": ["string", "null"]
        },
        "dose": {
          "type": ["string", "null"]
        },
        "status": {
          "$ref": "#/$defs/medication_status"
        },
        "missingness": {
          "$ref": "#/$defs/missingness"
        },
        "temporality": {
          "$ref": "#/$defs/temporality"
        },
        "reason_stopped": {
          "type": ["string", "null"]
        },
        "evidence": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "evidence_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "investigation_field": {
      "type": "object",
      "required": ["status", "result", "missingness", "temporality", "evidence", "evidence_event_ids"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/investigation_status"
        },
        "result": {
          "$ref": "#/$defs/investigation_result"
        },
        "missingness": {
          "$ref": "#/$defs/missingness"
        },
        "temporality": {
          "$ref": "#/$defs/temporality"
        },
        "evidence": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "evidence_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "seizure_frequency_field": {
      "type": "object",
      "required": [
        "value",
        "missingness",
        "temporality",
        "temporal_scope",
        "seizure_type",
        "evidence",
        "evidence_event_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": ["string", "null"]
        },
        "missingness": {
          "$ref": "#/$defs/missingness"
        },
        "temporality": {
          "$ref": "#/$defs/temporality"
        },
        "temporal_scope": {
          "type": ["string", "null"]
        },
        "seizure_type": {
          "type": ["string", "null"]
        },
        "evidence": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "evidence_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["id", "category", "temporality", "status", "value", "evidence"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "enum": ["medication", "seizure_frequency", "seizure_type", "investigation", "diagnosis"]
        },
        "temporality": {
          "$ref": "#/$defs/temporality"
        },
        "status": {
          "enum": [
            "current",
            "previous",
            "stopped",
            "declined",
            "planned",
            "increased",
            "reduced",
            "requested",
            "pending",
            "completed",
            "unavailable",
            "not_stated",
            "uncertain",
            null
          ]
        },
        "value": {
          "type": ["string", "null"]
        },
        "medication_name": {
          "type": ["string", "null"]
        },
        "dose": {
          "type": ["string", "null"]
        },
        "route": {
          "type": ["string", "null"]
        },
        "frequency": {
          "type": ["string", "null"]
        },
        "reason_stopped": {
          "type": ["string", "null"]
        },
        "temporal_scope": {
          "type": ["string", "null"]
        },
        "seizure_type": {
          "type": ["string", "null"]
        },
        "investigation_type": {
          "enum": ["EEG", "MRI", null]
        },
        "result": {
          "$ref": "#/$defs/investigation_result"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      }
    }
  }
}
